<Window x:Class="WindowsBar.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowsBar Settings"
        Height="240" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#1A1A2E">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2255AA"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <StackPanel Margin="24">
        <TextBlock Text="WindowsBar Settings"
                   Foreground="White" FontSize="16" FontWeight="SemiBold"
                   FontFamily="Segoe UI Variable Display" Margin="0,0,0,16"/>

        <CheckBox x:Name="ChkStartup" Content="Launch at Windows startup"
                  Checked="ChkStartup_Changed" Unchecked="ChkStartup_Changed"/>

        <Separator Margin="0,12" Background="#33FFFFFF"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Refresh Colors" Margin="0,0,8,0" Click="BtnRefreshColors_Click"/>
            <Button Content="Close" Click="BtnClose_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
